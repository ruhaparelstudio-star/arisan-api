# Server
PORT=3001
NODE_ENV=development

# Test bypass (set true agar nomor +628560000100 selalu bisa login dengan OTP 123456)
# AKTIFKAN saat deploy untuk Firebase Test Lab
ENABLE_TEST_BYPASS=false
