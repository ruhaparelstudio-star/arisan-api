# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Fonnte (WA notification)
FONNTE_TOKEN=
FONNTE_TIMEOUT_MS=3000

# Stream.io (Chat)
STREAM_API_KEY=
